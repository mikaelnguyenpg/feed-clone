{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.0/.schema/devbox.schema.json",
    "packages": [
      "rustup@latest",
      "nodejs_22@latest",
      "pnpm@latest",
      "postgresql@latest",
      "pkg-config@latest",
      "openssl.dev",
      "cargo-watch@latest",
      "cargo-expand@latest",
      "sqlx-cli@latest"
    ],
    "env": {
      "SQLX_OFFLINE": "false",
      "RUSTC_WRAPPER": "" 
    },
    "shell": {
      "init_hook": [
        "echo 'Welcome to devbox!' > /dev/null",
        "rustup default stable > /dev/null 2>&1",
        "rustup component add rust-analyzer rust-src clippy rustfmt > /dev/null 2>&1",
        "rustup target add wasm32-unknown-unknown > /dev/null 2>&1",
        "export PKG_CONFIG_PATH=\"$(devbox global info pkg-config --path)/lib/pkgconfig:$PKG_CONFIG_PATH\"",
        "echo '🚀 Môi trường Devbox cho Next.js & Rust đã sẵn sàng!'",
        "echo '🦀 Rust: $(rustc --version)'",
        "echo '⚛️ Node: $(node --version)'"
      ],
      "scripts": {
        "test": [
          "echo \"Error: no test specified\" && exit 1"
        ],
        "init:fe:ui": [
          "echo 1 && pwd && pnpm -C $DEVBOX_PROJECT_ROOT/fe/nextjs add -D tailwindcss postcss autoprefixer",
          "echo 2 && pwd && cd $DEVBOX_PROJECT_ROOT/fe/nextjs && pnpm dlx shadcn@latest init --template next",
          "echo 3 && pwd && cd $DEVBOX_PROJECT_ROOT/fe/nextjs && pnpm dlx shadcn@latest add button card input dropdown-menu avatar"
        ],
        "init:fe:libs": [
          "echo 4 && pwd && pnpm -C $DEVBOX_PROJECT_ROOT/fe/nextjs add next-themes lucide-react",
          "echo 5 && pwd && pnpm -C $DEVBOX_PROJECT_ROOT/fe/nextjs add @tanstack/react-virtual @tanstack/react-query-devtools",
          "echo 6 && pwd && pnpm -C $DEVBOX_PROJECT_ROOT/fe/nextjs add -D @faker-js/faker"
        ],
        "init:fe": [
          "devbox run init:fe:ui",
          "devbox run init:fe:libs"
        ],
        "dev:fe": "pnpm -C $DEVBOX_PROJECT_ROOT/fe/nextjs dev",
        "dev:be": "cd be/axum-realworld && cargo watch -x run",
        "db:start": "pg_ctl -D .postgres_data -l logfile start",
        "db:stop": "pg_ctl -D .postgres_data stop"
      }
    }
  }
  
